#HTML
<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Apex Clone Pro</title>

<link rel="stylesheet" href="style.css">

<link href="https://fonts.googleapis.com/css2?family=Poppins:wght@300;400;600&display=swap" rel="stylesheet">
</head>

<body>

<!-- NAVBAR -->
<header class="navbar">
    <div class="logo">EVALUEER</div>
    <nav>
        <a href="#">Features</a>
        <a href="#">Workflow</a>
        <a href="#">Pricing</a>
        <button class="btn">Book Demo</button>
    </nav>
</header>

<!-- HERO -->
<section class="hero">
    <div class="overlay"></div>

    <div class="hero-content">
        <h1 class="fade-up"> Construction Estimating</h1>
        <p class="fade-up">Upload plans → Get accurate estimates instantly.</p>

        <div class="hero-buttons fade-up">
            <button class="btn">Start Free Trial</button>
            <button class="btn-outline">Watch Demo</button>
        </div>
    </div>
</section>

<!-- DASHBOARD PREVIEW -->
<section class="dashboard fade-up">
    <img src="https://via.placeholder.com/900x500" alt="dashboard">
</section>

<!-- FEATURES -->
<section class="features">
    <h2 class="fade-up">Everything You Need</h2>

    <div class="grid">
        <div class="card fade-up">
            <img src="https://via.placeholder.com/80">
            <h3>AI Detection</h3>
            <p>Detect materials automatically</p>
        </div>

        <div class="card fade-up">
            <img src="https://via.placeholder.com/80">
            <h3>Fast Takeoffs</h3>
            <p>Measure in seconds</p>
        </div>

        <div class="card fade-up">
            <img src="https://via.placeholder.com/80">
            <h3>Cloud Sync</h3>
            <p>Access anywhere</p>
        </div>
    </div>
</section>

<!-- WORKFLOW -->
<section class="workflow">
    <h2 class="fade-up">How It Works</h2>

    <div class="steps">
        <div class="step fade-up">Upload Plans</div>
        <div class="step fade-up">AI Analysis</div>
        <div class="step fade-up">Auto Measure</div>
        <div class="step fade-up">Generate Estimate</div>
    </div>
</section>

<!-- PRICING -->
<section class="pricing">
    <h2 class="fade-up">Pricing</h2>

    <div class="pricing-grid">
        <div class="price-card fade-up">
            <h3>Starter</h3>
            <p>$299/mo</p>
            <button class="btn">Choose</button>
        </div>

        <div class="price-card highlight fade-up">
            <h3>Pro</h3>
            <p>$699/mo</p>
            <button class="btn">Choose</button>
        </div>

        <div class="price-card fade-up">
            <h3>Enterprise</h3>
            <p>Custom</p>
            <button class="btn">Contact</button>
        </div>
    </div>
</section>

<!-- CTA -->
<section class="cta fade-up">
    <h2>Start Winning More Bids Today</h2>
    <button class="btn">Get Started</button>
</section>

<footer>
    <p>© 2026 Apex Clone</p>
</footer>

<script src="script.js"></script>

</body>
</html>
